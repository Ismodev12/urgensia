# ============================================================
#  URGENSIA API — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Base de données PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=urgensia_db
DB_USER=postgres
DB_PASSWORD=VOTRE_MOT_DE_PASSE_ICI

# ── JWT — Access Token (15 minutes) ──────────────────────────
JWT_SECRET=CHANGER_CETTE_CLE_SECRETE_TRES_LONGUE_ET_ALEATOIRE
JWT_EXPIRES_IN=15m

# ── JWT — Refresh Token (7 jours) ────────────────────────────
JWT_REFRESH_SECRET=AUTRE_CLE_SECRETE_DIFFERENTE_DE_LA_PRECEDENTE
JWT_REFRESH_EXPIRES_IN=7d
