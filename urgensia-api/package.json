{
  "name": "urgensia-api",
  "version": "1.0.0",
  "description": "Backend URGENSIA — API REST + WebSocket (Manchester Triage System)",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node --test",
    "db:migrate": "psql -U postgres -d urgensia_db -f src/db/migrations/001_init.sql",
    "db:seed": "psql -U postgres -d urgensia_db -f src/db/seeds/001_seed.sql",
    "db:reset": "psql -U postgres -c \"DROP DATABASE IF EXISTS urgensia_db; CREATE DATABASE urgensia_db;\" && npm run db:migrate && npm run db:seed",
    "hash": "node -e \"const b=require('bcryptjs'); b.hash(process.argv[1],10).then(h=>console.log(h))\" "
  },
  "keywords": [
    "healthcare",
    "triage",
    "manchester",
    "nodejs",
    "postgresql",
    "websocket"
  ],
  "author": "URGENSIA Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.5",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
